  "hero.stat1b": { en: "AI-assisted sessions", es: "Sesiones asistidas por IA" },
  "hero.stat2a": { en: "Native US", es: "EE.UU." },
  "hero.stat2b": { en: "English speaker", es: "Hablante nativo" },
  "hero.stat3a": { en: "MXN", es: "MXN" },
  "hero.stat3b": { en: "Pay in pesos", es: "Paga en pesos" },
  "who.eyebrow": { en: "Who This Is For", es: "Para quién es" },
  "who.title": { en: "This is for you if…", es: "Esto es para ti si…" },
  "who.desc": { en: "You already studied grammar. Now you need to actually speak.", es: "Ya estudiaste gramática. Ahora necesitas hablar de verdad." },
  "who.card1": { en: "You understand but freeze when speaking", es: "Entiendes pero te congelas al hablar" },
  "who.card1.desc": { en: "Your comprehension is good, but speaking feels impossible. This is the most common problem — and the one I solve.", es: "Tu comprensión es buena, pero hablar parece imposible. Este es el problema más común — y el que resuelvo." },
  "who.card2": { en: "You mentally translate every sentence", es: "Traduces mentalmente cada frase" },
  "who.card2.desc": { en: "You think in Spanish and translate to English in your head. We'll train your brain to think directly in English.", es: "Piensas en español y traduces a inglés en tu mente. Entrenaremos tu cerebro para pensar directamente en inglés." },
  "who.card3": { en: "You want remote work with US teams", es: "Quieres trabajo remoto con equipos de EE.UU." },
  "who.card3.desc": { en: "The opportunity is there. The only thing holding you back is confidence in English conversations.", es: "La oportunidad está ahí. Lo único que te detiene es la confianza en conversaciones en inglés." },
  "who.card4": { en: "You need English for interviews or meetings", es: "Necesitas inglés para entrevistas o reuniones" },
  "who.card4.desc": { en: "Job interviews, standups, client calls — we practice the exact situations you'll face.", es: "Entrevistas, standups, llamadas con clientes — practicamos las situaciones exactas que enfrentarás." },
  "who.card5": { en: "You're a developer or tech worker", es: "Eres desarrollador o trabajador de tecnología" },
  "who.card5.desc": { en: "Technical English, AI terminology, startup culture — I speak your language and can help with the specific vocabulary you need.", es: "Inglés técnico, terminología de IA, cultura startup — hablo tu idioma y puedo ayudarte con el vocabulario específico que necesitas." },
  "who.card6": { en: "You're tired of traditional English classes", es: "Estás cansado de clases tradicionales de inglés" },
  "who.card6.desc": { en: "No textbooks, no grammar drills, no repetitive worksheets. Just real conversation with a native speaker.", es: "Sin libros de texto, sin ejercicios de gramática, sin hojas repetitivas. Solo conversación real con un hablante nativo." },
  "focus.eyebrow": { en: "What We Focus On", es: "En qué nos enfocamos" },
  "focus.title": { en: "English first. Communication first.", es: "Inglés primero. Comunicación primero." },
  "focus.desc": { en: "Real conversations, not textbook exercises. Every session is designed to build confidence and natural speech.", es: "Conversaciones reales, no ejercicios de libro. Cada sesión está diseñada para construir confianza y habla natural." },
