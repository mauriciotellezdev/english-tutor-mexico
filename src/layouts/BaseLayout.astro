---
export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

const { title, description, canonical, ogImage } = Astro.props;
const siteUrl = "https://english-tutor-mexico.pages.dev";
const defaultDesc = "Personalized online English lessons for professionals in Mexico. Native US English speaker — conversation, interviews, and confidence.";
const defaultOgImage = ogImage ?? "https://avatars.githubusercontent.com/u/282408621?v=4";
const pageUrl = canonical ?? Astro.url.pathname;
---

<!doctype html>
<html lang="es" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description ?? defaultDesc} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={`${siteUrl}${pageUrl}`} />
    
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`${siteUrl}${pageUrl}`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description ?? defaultDesc} />
    <meta property="og:image" content={defaultOgImage} />
    <meta property="og:locale" content="es_MX" />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description ?? defaultDesc} />
    <meta name="twitter:image" content={defaultOgImage} />

    <!-- Geo tags for Mexico targeting -->
    <meta name="geo.region" content="MX" />
    <meta name="geo.placename" content="Mexico" />

    <!-- JSON-LD structured data -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Mauricio Tellez",
        "jobTitle": "English Coach & Software Engineer",
        "description": "Native US English speaker offering personalized English coaching for professionals in Mexico",
        "url": "https://english-tutor-mexico.pages.dev",
        "image": "https://avatars.githubusercontent.com/u/282408621?v=4",
        "knowsLanguage": ["en", "es"],
        "address": { "@type": "PostalAddress", "addressCountry": "MX" }
      }
    </script>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Service",
        "name": "English Coaching Mexico",
        "description": "One-on-one English coaching from a native US English speaker. Personalized sessions for professionals in Mexico.",
        "provider": { "@type": "Person", "name": "Mauricio Tellez" },
        "areaServed": { "@type": "Country", "name": "MX" },
        "availableChannel": { "@type": "ServiceChannel", "serviceUrl": "https://english-tutor-mexico.pages.dev/book" }
      }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <script is:inline>
      window.__T = {
  "site.logo": { en: "English Coach", es: "Coach de Inglés" },
