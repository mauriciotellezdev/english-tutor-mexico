};
    </script>
    <script is:inline src="/i18n.js"></script>
    <style is:global>
      /* ---------- Theme variables ---------- */
      :root,
      [data-theme="light"] {
        --bg-primary: #f8fafc;
        --bg-secondary: #ffffff;
        --bg-glass: rgba(255,255,255,0.7);
        --text-primary: #0f172a;
        --text-secondary: #475569;
        --text-muted: #94a3b8;
        --border-subtle: rgba(0,0,0,0.08);
        --border-glass: rgba(0,0,0,0.06);
        --c-indigo: #6366f1;
        --c-indigo-light: #818cf8;
        --c-cyan: #22d3ee;
        --c-emerald: #34d399;
        --glow-indigo: rgba(99,102,241,0.08);
        --glow-cyan: rgba(6,182,212,0.06);
        --shadow-card: 0 4px 20px rgba(0,0,0,0.05);
        --header-bg: rgba(255,255,255,0.8);
        --badge-bg: rgba(99,102,241,0.08);
        --badge-border: rgba(99,102,241,0.15);
        --badge-text: #6366f1;
        --btn-primary-bg: #6366f1;
        --btn-primary-text: #fff;
        --btn-primary-shadow: rgba(99,102,241,0.25);
        --btn-secondary-bg: rgba(0,0,0,0.03);
        --btn-secondary-border: rgba(0,0,0,0.1);
        --cta-gradient: linear-gradient(135deg, rgba(99,102,241,0.08), rgba(6,182,212,0.04));
      }

      [data-theme="dark"] {
        --bg-primary: #020617;
        --bg-secondary: #0f172a;
        --bg-glass: rgba(15,23,42,0.65);
        --text-primary: #f8fafc;
        --text-secondary: #cbd5e1;
        --text-muted: #64748b;
        --border-subtle: rgba(255,255,255,0.06);
        --border-glass: rgba(255,255,255,0.08);
        --c-indigo: #818cf8;
        --c-indigo-light: #a5b4fc;
        --c-cyan: #22d3ee;
        --c-emerald: #34d399;
        --glow-indigo: rgba(99,102,241,0.15);
        --glow-cyan: rgba(6,182,212,0.10);
        --shadow-card: 0 20px 60px rgba(0,0,0,0.3);
        --header-bg: rgba(2,6,23,0.8);
        --badge-bg: rgba(99,102,241,0.12);
        --badge-border: rgba(99,102,241,0.2);
        --badge-text: #a5b4fc;
        --btn-primary-bg: #6366f1;
        --btn-primary-text: #fff;
        --btn-primary-shadow: rgba(99,102,241,0.3);
        --cta-gradient: linear-gradient(135deg, rgba(99,102,241,0.15), rgba(6,182,212,0.08));
      }

      /* ---------- Reset ---------- */
      *,
      *::before,
      *::after { box-sizing: border-box; margin: 0; padding: 0; }

      html { scroll-behavior: smooth; }
      body {
        font-family: "Inter", system-ui, -apple-system, sans-serif;
        background: var(--bg-primary);
        color: var(--text-secondary);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        line-height: 1.7;
        -webkit-font-smoothing: antialiased;
        transition: background 0.3s, color 0.3s;
      }

      a { color: var(--c-indigo); text-decoration: none; }
      a:hover { color: var(--c-indigo-light); }

      img { max-width: 100%; display: block; }

      .container {
        width: 100%;
        margin-inline: auto;
        max-width: 1120px;
        padding-inline: 1.5rem;
      }
      @media (min-width: 1024px) {
        .container { padding-inline: 2rem; }
      }

      /* ---- Section system ---- */
      .section {
        position: relative;
        padding: 5rem 0;
      }
      @media (min-width: 768px) {
        .section { padding: 7rem 0; }
      }

      .section-divider::before {
        content: "";
        position: absolute;
        inset-inline: 0;
        top: 0;
        height: 1px;
        background: linear-gradient(to right, transparent, rgba(255,255,255,0.08), transparent);
        pointer-events: none;
      }

      .bg-subtle { background: rgba(255,255,255,0.015); }
      .bg-indigo-tint { background: rgba(99,102,241,0.025); }

      .surface {
        border-radius: 40px;
        border: 1px solid rgba(255,255,255,0.08);
        background: rgba(255,255,255,0.025);
        padding: 2rem;
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
      }
      @media (min-width: 768px) {
        .surface { padding: 3rem; }
      }

      .mini-section {
        max-width: 640px;
        margin: 0 auto;
        text-align: center;
      }
      .mini-section .section-eyebrow {
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--c-indigo);
        margin-bottom: 1rem;
      }
      .mini-section .section-eyebrow-light {
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: #64748b;
        margin-bottom: 1rem;
      }
      .mini-section h2 {
        font-size: clamp(1.75rem, 4vw, 2.75rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        color: #fff;
        line-height: 1.15;
      }
      .mini-section p {
        margin-top: 1.25rem;
        font-size: 1.125rem;
        line-height: 1.8;
        color: #94a3b8;
      }

      .bg-glow {
        pointer-events: none;
        position: fixed;
        inset: 0;
        overflow: hidden;
        z-index: -1;
      }
      .bg-glow::before {
        content: "";
        position: absolute;
        left: -10%;
        top: 0;
        width: 500px;
        height: 500px;
        border-radius: 50%;
        background: var(--glow-indigo);
        filter: blur(100px);
      }
      .bg-glow::after {
        content: "";
        position: absolute;
        right: -5%;
        bottom: -10%;
        width: 600px;
        height: 600px;
        border-radius: 50%;
        background: var(--glow-cyan);
        filter: blur(120px);
      }

      .glass {
        background: var(--bg-glass);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid var(--border-glass);
        transition: all 0.3s;
      }
      .glass:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-card);
      }

      .section-border {
        border-top: 1px solid var(--border-subtle);
      }

      .btn-primary,
      .btn-secondary {
        display: inline-flex;
        align-items: center;
        padding: 0.75rem 2rem;
        border-radius: 16px;
        font-weight: 600;
        font-size: 0.9rem;
        transition: all 0.2s;
        text-decoration: none !important;
        background: var(--btn-secondary-bg, rgba(255,255,255,0.05));
        color: var(--text-primary) !important;
        border: 1px solid var(--btn-secondary-border, var(--border-glass));
      }
      .btn-secondary:hover {
        background: var(--btn-secondary-bg, rgba(255,255,255,0.1));
        border-color: rgba(255,255,255,0.2);
      }

      .btn-primary {
        background: var(--btn-primary-bg);
        color: var(--btn-primary-text) !important;
        box-shadow: 0 4px 14px var(--btn-primary-shadow);
      }
      .btn-primary:hover {
        background: var(--c-indigo-light);
        box-shadow: 0 6px 20px var(--btn-primary-shadow);
      }

      .btn-secondary {
        background: rgba(255,255,255,0.05);
        color: var(--text-primary) !important;
        border: 1px solid var(--border-glass);
      }
      .btn-secondary:hover {
        background: rgba(255,255,255,0.1);
        border-color: rgba(255,255,255,0.2);
      }

      .section-label {
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--c-indigo);
        margin-bottom: 1rem;
      }
      .section-title {
        font-size: clamp(1.75rem, 4vw, 2.75rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        color: var(--text-primary);
        line-height: 1.15;
      }
      .section-desc {
        font-size: 1.05rem;
        color: var(--text-muted);
        margin-top: 1rem;
        max-width: 560px;
      }

      .section-block {
        padding: 5rem 0;
      }
      @media (min-width: 768px) {
        .section-block { padding: 6rem 0; }
      }

      /* ---------- Header ---------- */
      header {
        position: sticky;
        top: 0;
        z-index: 50;
        background: var(--header-bg);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-bottom: 1px solid var(--border-subtle);
      }
      header .container {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-block: 0.85rem;
      }
      .logo {
        font-weight: 700;
        font-size: 1.05rem;
        color: var(--text-primary) !important;
        letter-spacing: -0.02em;
      }
      .logo:hover { opacity: 0.8; }
      .logo span { color: var(--c-indigo); }

      .header-right {
        display: flex;
        align-items: center;
        gap: 1rem;
      }

      nav { display: flex; gap: 1.5rem; align-items: center; }
      nav a { font-size: 0.9rem; font-weight: 500; color: var(--text-muted); transition: color 0.2s; }
      nav a:hover { color: var(--text-primary); }
      nav a.btn-book { color: #fff !important; }
      .btn-book {
        background: var(--btn-primary-bg) !important;
        color: var(--btn-primary-text) !important;
        padding: 0.5rem 1.35rem !important;
        border-radius: 12px !important;
        font-weight: 600 !important;
        font-size: 0.85rem !important;
        white-space: nowrap;
      }
      .btn-book:hover { background: var(--c-indigo-light) !important; }

      .lang-select {
        background: rgba(255,255,255,0.06);
        color: var(--c-indigo);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 8px;
        padding: 0.35rem 0.6rem;
        font-size: 0.75rem;
        font-weight: 700;
        font-family: inherit;
        cursor: pointer;
        letter-spacing: 0.04em;
        outline: none;
        transition: border-color 0.2s;
      }
      .lang-select:hover { border-color: var(--c-indigo); }
      .lang-select optgroup,
      .lang-select option { background: #0f172a; color: #fff; }

      .nav-toggle {
        display: none;
        background: none;
        border: none;
        font-size: 1.5rem;
        cursor: pointer;
        color: var(--text-muted);
      }

      .lang-select-footer { display: none; }

      @media (width <= 640px) {
        .lang-select-header { display: none; }
        .lang-select-footer { display: inline-block; }
        .nav-toggle { display: block; }
        .header-right nav {
          display: none;
          flex-direction: column;
          position: absolute;
          top: 100%;
          left: 0;
          right: 0;
          background: var(--header-bg);
          backdrop-filter: blur(16px);
          padding: 1rem 5%;
          border-bottom: 1px solid var(--border-subtle);
          gap: 0.75rem;
        }
        .header-right nav.open { display: flex; }
      }

      /* ---------- Footer ---------- */
      footer {
        border-top: 1px solid var(--border-subtle);
        padding: 3rem 0;
      }
      footer .container {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 1.5rem;
      }
      .footer-brand {
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--text-primary);
      }
      .footer-brand span { color: var(--c-indigo); }
      .footer-desc {
        font-size: 0.85rem;
        color: var(--text-muted);
        max-width: 360px;
        line-height: 1.6;
        margin-top: 0.35rem;
      }
      .footer-links {
        display: flex;
        flex-wrap: wrap;
        gap: 1.5rem;
        font-size: 0.85rem;
      }
      .footer-links a { color: var(--text-muted); }
      .footer-links a:hover { color: var(--c-indigo); }

      /* ---------- Page header ---------- */
      .page-header {
        padding: 5rem 0 2rem;
        text-align: center;
      }
      .page-header h1 {
        font-size: clamp(2rem, 5vw, 3.5rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        color: var(--text-primary);
      }
      .page-header p {
        font-size: 1.05rem;
        color: var(--text-muted);
        margin-top: 0.75rem;
        max-width: 560px;
        margin-inline: auto;
      }

      /* ---------- WhatsApp floating button removed — now inline in hero CTA ---------- */
    </style>
  </head>
  <body>
    <!-- Background glow -->
    <div class="bg-glow"></div>

    <header>
      <div class="container">
        <a href="/" class="logo">Mauricio Tellez <span>|</span> <span data-i18n="site.logo">English Coach</span></a>
        <div class="header-right">
          <nav id="nav">
            <a href="/" data-i18n="nav.home">Inicio</a>
            <a href="/pricing" data-i18n="nav.pricing">Precios</a>
            <a href="/about" data-i18n="nav.about">Sobre mí</a>
            <a href="/book" class="btn-book" data-i18n="nav.book">Consulta Gratis</a>
          </nav>
          <select class="lang-select lang-select-header" id="langSelect" aria-label="Language">
            <option value="es">ES</option>
            <option value="en">EN</option>
          </select>
          <button class="nav-toggle" id="navToggle" aria-label="Menu">☰</button>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="container">
        <div>
          <div class="footer-brand">English Coaching <span>in Mexico</span></div>
          <p class="footer-desc" data-i18n="footer.desc">Coaching de inglés por Mauricio Tellez — hablante nativo de EE.UU. e ingeniero de software.</p>
        </div>
        <div class="footer-links">
          <a href="/pricing">Precios</a>
          <a href="/about">Sobre mí</a>
          <a href="/book">Agendar</a>
          <a href="/privacy">Privacidad</a>
          <a href="https://github.com/mauriciotellezdev" target="_blank" rel="noopener">GitHub</a>
        </div>
        <select class="lang-select lang-select-footer" aria-label="Language">
          <option value="es">ES</option>
          <option value="en">EN</option>
        </select>
      </div>
    </footer>

    <!-- WhatsApp floating button removed — now inline in hero CTA -->

    <script>
      // Language switcher
      var langSelects = document.querySelectorAll(".lang-select");
      var savedLang = localStorage.getItem("lang") || "es";
      langSelects.forEach(function(s) { s.value = savedLang; });
      if (window.__switchLang) window.__switchLang(savedLang);
      langSelects.forEach(function(s) {
        s.addEventListener("change", function() {
          if (window.__switchLang) window.__switchLang(this.value);
        });
      });

      // Mobile nav
      document.getElementById("navToggle")?.addEventListener("click", function() {
        document.getElementById("nav")?.classList.toggle("open");
      });
    </script>
  </body>
</html>
