  "hero.heading2": { en: "with a native US engineer", es: "con un ingeniero nativo de EE.UU." },
  "hero.subtitle": { en: "AI-assisted conversational English immersion with a native US software engineer. Stop translating in your head. Start thinking in English.", es: "Inmersión conversacional en inglés asistida por IA con un ingeniero de software nativo de EE.UU. Deja de traducir en tu mente. Empieza a pensar en inglés." },
