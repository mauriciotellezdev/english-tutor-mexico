  "focus.item1.desc": { en: "Train your brain to think in English directly. No more mental translation.", es: "Entrena tu cerebro para pensar en inglés directamente. Sin más traducción mental." },
  "focus.item2": { en: "Overcoming fear and hesitation", es: "Superar el miedo y la hesitación" },
  "focus.item2.desc": { en: "A relaxed environment where mistakes are normal and expected. Confidence comes from practice.", es: "Un ambiente relajado donde los errores son normales y esperados. La confianza viene de la práctica." },
  "focus.item3": { en: "Understanding real spoken English", es: "Entender inglés hablado real" },
  "focus.item3.desc": { en: "Native speed, natural expressions, connected speech — the English you actually hear in real life.", es: "Velocidad nativa, expresiones naturales, habla conectada — el inglés que realmente escuchas en la vida real." },
  "focus.item4": { en: "Interview and meeting preparation", es: "Preparación para entrevistas y reuniones" },
  "focus.item4.desc": { en: "Practice the exact conversations you'll have in interviews, standups, and client calls.", es: "Practica las conversaciones exactas que tendrás en entrevistas, standups y llamadas con clientes." },
  "focus.item5": { en: "Tech and professional vocabulary", es: "Vocabulario técnico y profesional" },
  "focus.item5.desc": { en: "Slack messages, Zoom calls, bug reports, presentations — English for your actual work.", es: "Mensajes de Slack, llamadas de Zoom, reportes de bugs, presentaciones — inglés para tu trabajo real." },
  "focus.item6": { en: "Pronunciation and natural rhythm", es: "Pronunciación y ritmo natural" },
  "focus.item6.desc": { en: "Sound more natural and be understood effortlessly. Focus on clarity, not perfection.", es: "Suena más natural y que te entiendan sin esfuerzo. Enfoque en claridad, no perfección." },
  "how.eyebrow": { en: "How Lessons Work", es: "Cómo funcionan las sesiones" },
  "how.title": { en: "Every session follows a proven structure", es: "Cada sesión sigue una estructura comprobada" },
  "how.desc": { en: "Five phases designed to maximize speaking time and build real confidence.", es: "Cinco fases diseñadas para maximizar el tiempo de habla y construir confianza real." },
  "how.step1.title": { en: "Warmup Conversation", es: "Conversación de Calentamiento" },
  "how.step1.desc": { en: "We start with simple daily-life discussion. Relaxed speaking practice to get you comfortable and thinking in English from minute one.", es: "Empezamos con una conversación simple de la vida diaria. Práctica relajada de habla para que te sientas cómodo y pienses en inglés desde el primer minuto." },
  "how.step2.title": { en: "Focus Topic", es: "Tema Principal" },
  "how.step2.desc": { en: "Job interviews, remote work, software development, travel, meetings, customer communication, gaming, daily life — we pick what matters to you.", es: "Entrevistas de trabajo, trabajo remoto, desarrollo de software, viajes, reuniones, comunicación con clientes, gaming, vida diaria — elegimos lo que te importa." },
  "how.step3.title": { en: "Correction Pass", es: "Correcciones Selectivas" },
  "how.step3.desc": { en: "Only a few important corrections. We focus on natural speech patterns, not perfection. Confidence comes first.", es: "Solo unas pocas correcciones importantes. Nos enfocamos en patrones de habla natural, no en perfección. La confianza es primero." },
  "how.step4.title": { en: "Roleplay Practice", es: "Práctica con Roleplay" },
  "how.step4.desc": { en: "Interviews, meetings, restaurants, customer support, talking with coworkers, technical explanations — we simulate real situations.", es: "Entrevistas, reuniones, restaurantes, soporte al cliente, hablar con compañeros, explicaciones técnicas — simulamos situaciones reales." },
  "how.step5.title": { en: "Practical Homework", es: "Tarea Práctica" },
  "how.step5.desc": { en: "Voice recordings, YouTube videos, describing your daily activities in English — small tasks that keep you immersed between sessions.", es: "Grabaciones de voz, videos de YouTube, describir tus actividades diarias en inglés — tareas pequeñas que te mantienen inmerso entre sesiones." },
  "why.eyebrow": { en: "Why This Works", es: "Por qué funciona" },
  "why.title": { en: "Why this approach works better", es: "Por qué este enfoque funciona mejor" },
  "why.desc": { en: "Most people already studied grammar. The real problem is different.", es: "La mayoría ya estudió gramática. El problema real es diferente." },
  "why.point1.title": { en: "You already know the grammar", es: "Ya sabes la gramática" },
  "why.point1.desc": { en: "Most English learners have years of grammar study. The problem isn't knowledge — it's putting it into practice under pressure.", es: "La mayoría de estudiantes de inglés tienen años de estudio de gramática. El problema no es conocimiento — es ponerlo en práctica bajo presión." },
  "why.point2.title": { en: "Fear is the real barrier", es: "El miedo es la barrera real" },
  "why.point2.desc": { en: "Students freeze because they're afraid of making mistakes. Our relaxed sessions remove that pressure so you can actually speak.", es: "Los estudiantes se congelan porque tienen miedo de cometer errores. Nuestras sesiones relajadas eliminan esa presión para que puedas hablar de verdad." },
  "why.point3.title": { en: "Mental translation slows you down", es: "La traducción mental te ralentiza" },
  "why.point3.desc": { en: "When you translate every sentence in your head, you speak slowly and sound unnatural. Immersion trains your brain to think directly in English.", es: "Cuando traduces cada frase en tu mente, hablas lento y suenas antinatural. La inmersión entrena tu cerebro para pensar directamente en inglés." },
  "why.point4.title": { en: "AI support removes embarrassment", es: "El apoyo de IA elimina la vergüenza" },
  "why.point4.desc": { en: "AI tools help when you get stuck — providing translations and explanations so the session stays in English without awkward pauses.", es: "Las herramientas de IA ayudan cuando te quedas atascado — proporcionando traducciones y explicaciones para que la sesión se mantenga en inglés sin pausas incómodas." },
  "why.point5.title": { en: "Conversation builds fluency faster", es: "La conversación construye fluidez más rápido" },
  "why.point5.desc": { en: "Constant conversational exposure is how humans naturally learn language. More speaking time = faster progress. Period.", es: "La exposición conversacional constante es como los humanos aprenden lenguaje naturalmente. Más tiempo hablando = progreso más rápido. Punto." },
  "tech.eyebrow": { en: "Tech & Remote Work", es: "Tecnología y Trabajo Remoto" },
  "tech.title": { en: "English for Tech & Remote Work", es: "Inglés para Tecnología y Trabajo Remoto" },
  "tech.desc": { en: "A specialized track for developers, IT workers, and remote professionals who need to communicate effectively with US teams.", es: "Un track especializado para desarrolladores, trabajadores de TI y profesionales remotos que necesitan comunicarse efectivamente con equipos de EE.UU." },
  "tech.card1.title": { en: "Slack & async communication", es: "Slack y comunicación asíncrona" },
  "tech.card1.desc": { en: "Write clear messages, participate in threads, and communicate effectively without being in the same timezone.", es: "Escribe mensajes claros, participa en hilos y comunícate efectivamente sin estar en la misma zona horaria." },
  "tech.card2.title": { en: "Zoom calls & meetings", es: "Llamadas de Zoom y reuniones" },
  "tech.card2.desc": { en: "Speak up in standups, contribute to discussions, and handle Q&A with confidence.", es: "Participa en standups, contribuye a discusiones y maneja preguntas y respuestas con confianza." },
  "tech.card3.title": { en: "Job interviews", es: "Entrevistas de trabajo" },
  "tech.card3.desc": { en: "Technical interviews, behavioral questions, salary negotiations — practice the exact conversations you'll face.", es: "Entrevistas técnicas, preguntas de comportamiento, negociaciones de salario — practica las conversaciones exactas que enfrentarás." },
  "tech.card4.title": { en: "Explaining bugs & technical issues", es: "Explicar bugs y problemas técnicos" },
  "tech.card4.desc": { en: "Describe problems clearly, propose solutions, and communicate technical concepts to non-technical stakeholders.", es: "Describe problemas claramente, propone soluciones y comunica conceptos técnicos a personas no técnicas." },
  "tech.card5.title": { en: "Presentations & demos", es: "Presentaciones y demos" },
  "tech.card5.desc": { en: "Present your work, demo features, and handle questions from US-based teams and clients.", es: "Presenta tu trabajo, demuestra funcionalidades y maneja preguntas de equipos y clientes en EE.UU." },
  "tech.card6.title": { en: "Startup culture & AI terminology", es: "Cultura startup y terminología de IA" },
  "tech.card6.desc": { en: "Understand startup jargon, AI/ML terminology, and the informal communication style of tech companies.", es: "Entiende la jerga startup, terminología de IA/ML y el estilo de comunicación informal de empresas de tecnología." },
  "relaxed.eyebrow": { en: "No pressure", es: "Sin presiones" },
  "relaxed.title": { en: "Relaxed sessions. Real progress.", es: "Sesiones relajadas. Progreso real." },
  "relaxed.desc": { en: "Lessons are conversational and adapted to your pace. Mistakes are normal and expected. The goal is real communication and growing confidence — not perfection.", es: "Las sesiones son conversacionales y se adaptan a tu ritmo. Los errores son normales y esperados. La meta es la comunicación real y creciente confianza — no la perfección." },
  "relaxed.btn": { en: "Book Free Consultation", es: "Agendar Consulta Gratis" },
  "faq.eyebrow": { en: "FAQ", es: "FAQ" },
  "faq.title": { en: "Common questions", es: "Preguntas frecuentes" },
  "faq.q1": { en: "Do I need perfect English?", es: "¿Necesito inglés perfecto?" },
  "faq.a1": { en: "No. Sessions are adapted to your level. The only requirement is that you want to speak more.", es: "No. Las sesiones se adaptan a tu nivel. El único requisito es que quieras hablar más." },
  "faq.q2": { en: "Are lessons online?", es: "¿Las sesiones son en línea?" },
  "faq.a2": { en: "Yes — via Google Meet, Zoom, or Discord. Your choice.", es: "Sí — por Google Meet, Zoom o Discord. Tú eliges." },
  "faq.q3": { en: "Can you help with job interviews?", es: "¿Puedes ayudar con entrevistas de trabajo?" },
  "faq.a3": { en: "Yes. Interview preparation is one of my main specialties. We practice the exact questions you'll face.", es: "Sí. La preparación de entrevistas es una de mis especialidades principales. Practicamos las preguntas exactas que enfrentarás." },
  "faq.q4": { en: "Is this like a traditional English class?", es: "¿Esto es como una clase tradicional de inglés?" },
  "faq.a4": { en: "No. There are no textbooks, grammar drills, or worksheets. Every session is conversation-based with real-world topics.", es: "No. No hay libros de texto, ejercicios de gramática ni hojas de trabajo. Cada sesión está basada en conversación con temas del mundo real." },
  "faq.q5": { en: "What level do I need?", es: "¿Qué nivel necesito?" },
  "faq.a5": { en: "If you can understand basic English, you're ready. We focus on speaking from day one.", es: "Si puedes entender inglés básico, estás listo. Nos enfocamos en hablar desde el día uno." },
  "faq.q6": { en: "Can I reschedule?", es: "¿Puedo reagendar?" },
  "faq.a6": { en: "Yes, with 24 hours advance notice.", es: "Sí, con 24 horas de aviso." },
  "faq.q7": { en: "How does AI help during sessions?", es: "¿Cómo ayuda la IA durante las sesiones?" },
  "faq.a7": { en: "AI tools provide quick translations and explanations when you get stuck, so we can keep the conversation flowing in English.", es: "Las herramientas de IA proporcionan traducciones y explicaciones rápidas cuando te quedas atascado, para que podamos mantener la conversación fluyendo en inglés." },
  "cta.title": { en: "Ready to think in English?", es: "¿Listo para pensar en inglés?" },
  "cta.desc": { en: "Book your free consultation and start speaking with real confidence.", es: "Agenda tu consulta gratis y empieza a hablar con confianza real." },
  "cta.btn": { en: "Start Your Free Consultation", es: "Agenda tu Consulta Gratis" },
  "footer.desc": { en: "AI-assisted English immersion by Mauricio Tellez — native US English speaker and software engineer.", es: "Inmersión en inglés asistida por IA por Mauricio Tellez — hablante nativo de EE.UU. e ingeniero de software." }
