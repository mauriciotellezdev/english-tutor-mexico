---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Agendar Clase">
  <section class="page-header">
    <div class="container">
      <div class="section-label">Agendar</div>
      <h1>Consulta Gratis</h1>
      <p>Agenda una llamada de 20 minutos sin costo para conocer tu nivel y tus metas.</p>
    </div>
  </section>

  <section class="section-block" style="padding-top: 2rem;">
    <div class="container" style="max-width: 600px; margin: 0 auto;">
      <div class="glass booking-card">
        <h3>¿Listo para empezar?</h3>
        <p style="font-size: 0.9rem; color: var(--text-muted); line-height: 1.6;">
          Elige un plan en Precios y paga via Stripe para agendar tu clase.
          Te contactaré personalmente para coordinar el horario.
        </p>
        <a href="/pricing" class="btn-primary" style="width: 100%; justify-content: center; display: flex; margin-top: 1rem;">
          Ver Planes y Precios
        </a>
      </div>

      <div class="glass booking-card">
        <h3>¿Prefieres probar primero?</h3>
        <p style="font-size: 0.9rem; color: var(--text-muted); line-height: 1.6; margin-bottom: 1rem;">
          Agenda una consulta gratuita de 20 minutos para conocernos.
        </p>
        <!-- Calendly inline widget begin -->
        <div class="calendly-inline-widget" data-url="https://calendly.com/mauriciotellezdev/consulta-gratis?hide_event_type_details=1&hide_gdpr_banner=1&background_color=020617&text_color=ffffff" style="min-width:320px;height:700px;"></div>
        <script type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async></script>
        <!-- Calendly inline widget end -->
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
  .booking-card { padding: 1.5rem; border-radius: 20px; margin-bottom: 1.5rem; }
  .booking-card h3 { font-size: 1rem; font-weight: 700; color: var(--text-primary); margin-bottom: 1rem; }
</style>
