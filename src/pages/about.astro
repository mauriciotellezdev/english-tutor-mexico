---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="About Mauricio Tellez | AI-Assisted English Immersion Coach" description="Native US English speaker and software engineer offering AI-assisted conversational English immersion for professionals in Mexico.">
  <section class="page-header">
    <div class="container">
      <div class="section-label">About</div>
      <h1>Meet Mauricio Tellez</h1>
      <p>Native US English speaker and software engineer — raised in California, now living in Mexico City.</p>
    </div>
  </section>

  <section class="section-block" style="padding-top: 2rem;">
    <div class="container">
      <div class="about-grid">
        <div class="about-photo-col">
          <img src="https://avatars.githubusercontent.com/u/282408621?v=4" alt="Mauricio Tellez" class="about-photo" width="360" height="450" />
          <div class="glass about-photo-badge">
            <div class="badge-label">Native US English speaker</div>
            <div class="badge-value">Software Engineer</div>
          </div>
        </div>
        <div class="about-text">
          <div class="section-label">Background</div>
          <h2 class="section-title">Native fluency meets software engineering</h2>
          
          <p class="about-p">I'm a software engineer raised in California, now living in Mexico City. I help professionals become comfortable speaking English through AI-assisted conversational immersion — not traditional grammar lessons.</p>
          
          <p class="about-p">My students are developers, remote workers, job seekers, and anyone who needs English for real situations. I've seen firsthand how strong communication skills open doors — better jobs, international teams, and real confidence.</p>

          <div class="about-highlight">
            <strong>English first. Communication first.</strong>
            <span>No textbooks. No grammar drills. Just real conversation.</span>
          </div>

          <!-- Teaching Philosophy -->
          <div style="margin-top: 2.5rem;">
            <div class="section-label">My Approach</div>
            <h3 class="about-h3">AI-assisted conversational immersion</h3>
            <p class="about-p">Most people already studied grammar. The real problem is fear and lack of speaking practice. My sessions use AI tools to help when you get stuck — providing quick translations and explanations so we can keep the conversation flowing in English. The result: less anxiety, more speaking time, faster progress.</p>
          </div>

          <!-- Good fit if -->
          <div style="margin-top: 2.5rem;">
            <div class="section-label">Good Fit If…</div>
            <ul class="about-fit-list">
              <li>✓ You understand English but freeze when speaking</li>
              <li>✓ You mentally translate every sentence before saying it</li>
              <li>✓ You want to work remotely with US teams</li>
              <li>✓ You need English for interviews, meetings, or presentations</li>
              <li>✓ You prefer real conversation over textbook exercises</li>
            </ul>
          </div>

          <a href="/book" class="btn-primary" style="margin-top: 1.5rem;">Book Free Consultation</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
  .about-grid { display: grid; gap: 3rem; align-items: start; }
  @media (min-width: 768px) { .about-grid { grid-template-columns: 360px 1fr; } }
  .about-photo-col { position: relative; display: flex; flex-direction: column; align-items: center; }
  .about-photo { width: 320px; height: 400px; border-radius: 32px; object-fit: cover; box-shadow: var(--shadow-card); }
  .about-photo-badge { margin-top: 1.5rem; padding: 0.75rem 1.25rem; border-radius: 16px; text-align: center; width: 100%; max-width: 320px; }
  .about-photo-badge .badge-label { font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; }
  .about-photo-badge .badge-value { font-size: 0.9rem; font-weight: 700; color: var(--text-primary); margin-top: 0.1rem; }
  .about-text { max-width: 600px; }
  .about-p { font-size: 1rem; color: var(--text-secondary); line-height: 1.8; margin-top: 1.25rem; }
  .about-h3 { font-size: 1.25rem; font-weight: 700; color: var(--text-primary); margin-top: 0.5rem; }
  .about-highlight {
    margin-top: 1.5rem; padding: 1rem 1.25rem; border-radius: 16px;
    background: rgba(99,102,241,0.08); border: 1px solid rgba(99,102,241,0.15);
    display: flex; flex-direction: column; gap: 0.2rem;
  }
  .about-highlight strong { font-size: 0.95rem; color: var(--text-primary); }
  .about-highlight span { font-size: 0.85rem; color: var(--text-muted); }
  .about-fit-list { list-style: none; margin-top: 1rem; display: flex; flex-direction: column; gap: 0.6rem; }
  .about-fit-list li { font-size: 0.95rem; color: var(--text-secondary); }
</style>
