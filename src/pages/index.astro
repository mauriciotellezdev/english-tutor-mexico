---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="English Immersion in Mexico | AI-Assisted Conversational Coaching" description="AI-assisted conversational English immersion with a native US software engineer. Stop translating in your head. Start thinking in English.">
  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="hero-glow">
      <div class="hero-glow-indigo"></div>
      <div class="hero-glow-cyan"></div>
    </div>
    <div class="hero-grid">
      <div class="hero-left">
        <div class="hero-badge">
          <span class="hero-badge-dot"></span>
          <span data-i18n="hero.badge">AI-assisted conversational immersion</span>
        </div>
        <h1 class="hero-heading">
          <span data-i18n="hero.heading1">Speak English naturally</span>
          <span class="hero-heading-gradient" data-i18n="hero.heading2">with a native US engineer</span>
        </h1>
        <p class="hero-subtitle" data-i18n="hero.subtitle">
          AI-assisted conversational English immersion with a native US software engineer. Stop translating in your head. Start thinking in English.
        </p>
        <div class="hero-cta">
          <a href="/book" class="hero-btn-primary" data-i18n="hero.btn1">Book Free Consultation</a>
          <a href="/pricing" class="hero-btn-secondary" data-i18n="hero.btn2">View Pricing</a>
          <a href="https://wa.me/16193946221" target="_blank" rel="noopener" class="hero-btn-whatsapp">
            <svg class="whatsapp-inline-icon" viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            <span data-i18n="hero.btn3">Questions? Message me</span>
          </a>
        </div>
        <div class="hero-stats">
          <div>
            <div class="hero-stat-num" data-i18n="hero.stat1a">Conversation-first</div>
            <div class="hero-stat-label" data-i18n="hero.stat1b">AI-assisted sessions</div>
          </div>
          <div>
            <div class="hero-stat-num" data-i18n="hero.stat2a">Native US</div>
            <div class="hero-stat-label" data-i18n="hero.stat2b">English speaker</div>
          </div>
          <div>
            <div class="hero-stat-num" data-i18n="hero.stat3a">MXN</div>
            <div class="hero-stat-label" data-i18n="hero.stat3b">Pay in pesos</div>
          </div>
        </div>
      </div>
      <div class="hero-right">
        <div class="hero-frame">
          <img src="https://avatars.githubusercontent.com/u/282408621?v=4" alt="Mauricio Tellez" class="hero-img" loading="eager" />
        </div>
      </div>
    </div>
  </section>

  <!-- ===== WHO THIS IS FOR ===== -->
  <section class="section">
    <div class="container">
      <div class="mini-section" style="margin-bottom: 3rem;">
        <div class="section-eyebrow" data-i18n="who.eyebrow">Who This Is For</div>
        <h2 class="section-title" data-i18n="who.title">This is for you if…</h2>
        <p class="section-desc" data-i18n="who.desc">You already studied grammar. Now you need to actually speak.</p>
      </div>
      <div class="who-grid">
        <div class="who-card">
          <div class="who-card-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          </div>
          <h3 data-i18n="who.card1">You understand but freeze when speaking</h3>
          <p data-i18n="who.card1.desc">Your comprehension is good, but speaking feels impossible. This is the most common problem — and the one I solve.</p>
        </div>
        <div class="who-card">
          <div class="who-card-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
          </div>
          <h3 data-i18n="who.card2">You mentally translate every sentence</h3>
          <p data-i18n="who.card2.desc">You think in Spanish and translate to English in your head. We'll train your brain to think directly in English.</p>
        </div>
        <div class="who-card">
          <div class="who-card-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>
          <h3 data-i18n="who.card3">You want remote work with US teams</h3>
          <p data-i18n="who.card3.desc">The opportunity is there. The only thing holding you back is confidence in English conversations.</p>
        </div>
        <div class="who-card">
          <div class="who-card-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </div>
          <h3 data-i18n="who.card4">You need English for interviews or meetings</h3>
          <p data-i18n="who.card4.desc">Job interviews, standups, client calls — we practice the exact situations you'll face.</p>
        </div>
        <div class="who-card">
          <div class="who-card-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          </div>
          <h3 data-i18n="who.card5">You're a developer or tech worker</h3>
          <p data-i18n="who.card5.desc">Technical English, AI terminology, startup culture — I speak your language and can help with the specific vocabulary you need.</p>
        </div>
        <div class="who-card">
          <div class="who-card-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
          </div>
          <h3 data-i18n="who.card6">You're tired of traditional English classes</h3>
          <p data-i18n="who.card6.desc">No textbooks, no grammar drills, no repetitive worksheets. Just real conversation with a native speaker.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== WHAT WE FOCUS ON ===== -->
  <section class="section bg-subtle">
    <div class="container">
      <div class="focus-header">
        <div class="section-eyebrow" data-i18n="focus.eyebrow">What We Focus On</div>
        <h2 class="section-title" data-i18n="focus.title">English first. Communication first.</h2>
        <p class="section-desc" data-i18n="focus.desc">Real conversations, not textbook exercises. Every session is designed to build confidence and natural speech.</p>
      </div>
      <div class="focus-grid">
        <div class="focus-item">
          <span class="focus-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          </span>
          <div>
            <strong data-i18n="focus.item1">Speaking naturally without translating</strong>
            <p data-i18n="focus.item1.desc">Train your brain to think in English directly. No more mental translation.</p>
          </div>
        </div>
        <div class="focus-item">
          <span class="focus-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </span>
          <div>
            <strong data-i18n="focus.item2">Overcoming fear and hesitation</strong>
            <p data-i18n="focus.item2.desc">A relaxed environment where mistakes are normal and expected. Confidence comes from practice.</p>
          </div>
        </div>
        <div class="focus-item">
          <span class="focus-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 16.1A5 5 0 0 1 5.9 20M2 12.05A9 9 0 0 1 9.95 20M2 8V6a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2h-6"/><circle cx="2" cy="20" r="2"/></svg>
          </span>
          <div>
            <strong data-i18n="focus.item3">Understanding real spoken English</strong>
            <p data-i18n="focus.item3.desc">Native speed, natural expressions, connected speech — the English you actually hear in real life.</p>
          </div>
        </div>
        <div class="focus-item">
          <span class="focus-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
          </span>
          <div>
            <strong data-i18n="focus.item4">Interview and meeting preparation</strong>
            <p data-i18n="focus.item4.desc">Practice the exact conversations you'll have in interviews, standups, and client calls.</p>
          </div>
        </div>
        <div class="focus-item">
          <span class="focus-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
          </span>
          <div>
            <strong data-i18n="focus.item5">Tech and professional vocabulary</strong>
            <p data-i18n="focus.item5.desc">Slack messages, Zoom calls, bug reports, presentations — English for your actual work.</p>
          </div>
        </div>
        <div class="focus-item">
          <span class="focus-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>
          </span>
          <div>
            <strong data-i18n="focus.item6">Pronunciation and natural rhythm</strong>
            <p data-i18n="focus.item6.desc">Sound more natural and be understood effortlessly. Focus on clarity, not perfection.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== HOW LESSONS WORK ===== -->
  <section class="section">
    <div class="container">
      <div class="mini-section" style="margin-bottom: 3.5rem;">
        <div class="section-eyebrow" data-i18n="how.eyebrow">How Lessons Work</div>
        <h2 class="section-title" data-i18n="how.title">Every session follows a proven structure</h2>
        <p class="section-desc" data-i18n="how.desc">Five phases designed to maximize speaking time and build real confidence.</p>
      </div>
      <div class="steps-grid">
        <div class="step-card">
          <div class="step-num">
            <span class="step-num-inner" style="color: #818cf8;">01</span>
          </div>
          <h3 data-i18n="how.step1.title">Warmup Conversation</h3>
          <p data-i18n="how.step1.desc">We start with simple daily-life discussion. Relaxed speaking practice to get you comfortable and thinking in English from minute one.</p>
        </div>
        <div class="step-card">
          <div class="step-num">
            <span class="step-num-inner" style="color: #22d3ee;">02</span>
          </div>
          <h3 data-i18n="how.step2.title">Focus Topic</h3>
          <p data-i18n="how.step2.desc">Job interviews, remote work, software development, travel, meetings, customer communication, gaming, daily life — we pick what matters to you.</p>
        </div>
        <div class="step-card">
          <div class="step-num">
            <span class="step-num-inner" style="color: #34d399;">03</span>
          </div>
          <h3 data-i18n="how.step3.title">Correction Pass</h3>
          <p data-i18n="how.step3.desc">Only a few important corrections. We focus on natural speech patterns, not perfection. Confidence comes first.</p>
        </div>
        <div class="step-card">
          <div class="step-num">
            <span class="step-num-inner" style="color: #fbbf24;">04</span>
          </div>
          <h3 data-i18n="how.step4.title">Roleplay Practice</h3>
          <p data-i18n="how.step4.desc">Interviews, meetings, restaurants, customer support, talking with coworkers, technical explanations — we simulate real situations.</p>
        </div>
        <div class="step-card">
          <div class="step-num">
            <span class="step-num-inner" style="color: #f472b6;">05</span>
          </div>
          <h3 data-i18n="how.step5.title">Practical Homework</h3>
          <p data-i18n="how.step5.desc">Voice recordings, YouTube videos, describing your daily activities in English — small tasks that keep you immersed between sessions.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== WHY THIS WORKS BETTER ===== -->
  <section class="section bg-subtle">
    <div class="container">
      <div class="mini-section" style="margin-bottom: 3.5rem;">
        <div class="section-eyebrow" data-i18n="why.eyebrow">Why This Works</div>
        <h2 class="section-title" data-i18n="why.title">Why this approach works better</h2>
        <p class="section-desc" data-i18n="why.desc">Most people already studied grammar. The real problem is different.</p>
      </div>
      <div class="why-grid">
        <div class="why-card">
          <div class="why-card-header">
            <div class="why-card-icon" style="background: rgba(99,102,241,0.12); color: #818cf8;">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
            </div>
            <h3 data-i18n="why.point1.title">You already know the grammar</h3>
          </div>
          <p data-i18n="why.point1.desc">Most English learners have years of grammar study. The problem isn't knowledge — it's putting it into practice under pressure.</p>
        </div>
        <div class="why-card">
          <div class="why-card-header">
            <div class="why-card-icon" style="background: rgba(244,114,182,0.12); color: #f472b6;">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <h3 data-i18n="why.point2.title">Fear is the real barrier</h3>
          </div>
          <p data-i18n="why.point2.desc">Students freeze because they're afraid of making mistakes. Our relaxed sessions remove that pressure so you can actually speak.</p>
        </div>
        <div class="why-card">
          <div class="why-card-header">
            <div class="why-card-icon" style="background: rgba(6,182,212,0.12); color: #22d3ee;">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
            </div>
            <h3 data-i18n="why.point3.title">Mental translation slows you down</h3>
          </div>
          <p data-i18n="why.point3.desc">When you translate every sentence in your head, you speak slowly and sound unnatural. Immersion trains your brain to think directly in English.</p>
        </div>
        <div class="why-card">
          <div class="why-card-header">
            <div class="why-card-icon" style="background: rgba(52,211,153,0.12); color: #34d399;">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 10 10H12V2z"/><path d="M20.66 9A10 10 0 0 0 14 2v6.66z" opacity="0.5"/></svg>
            </div>
            <h3 data-i18n="why.point4.title">AI support removes embarrassment</h3>
          </div>
          <p data-i18n="why.point4.desc">AI tools help when you get stuck — providing translations and explanations so the session stays in English without awkward pauses.</p>
        </div>
        <div class="why-card">
          <div class="why-card-header">
            <div class="why-card-icon" style="background: rgba(251,191,36,0.12); color: #fbbf24;">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
            </div>
            <h3 data-i18n="why.point5.title">Conversation builds fluency faster</h3>
          </div>
          <p data-i18n="why.point5.desc">Constant conversational exposure is how humans naturally learn language. More speaking time = faster progress. Period.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== ENGLISH FOR TECH & REMOTE WORK ===== -->
  <section class="section">
    <div class="container">
      <div class="tech-header">
        <div class="section-eyebrow" data-i18n="tech.eyebrow">Tech & Remote Work</div>
        <h2 class="section-title" data-i18n="tech.title">English for Tech & Remote Work</h2>
        <p class="section-desc" data-i18n="tech.desc">A specialized track for developers, IT workers, and remote professionals who need to communicate effectively with US teams.</p>
      </div>
      <div class="tech-grid">
        <div class="tech-card">
          <div class="tech-card-icon" style="background: rgba(99,102,241,0.10); color: #818cf8;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          </div>
          <h3 data-i18n="tech.card1.title">Slack & async communication</h3>
          <p data-i18n="tech.card1.desc">Write clear messages, participate in threads, and communicate effectively without being in the same timezone.</p>
        </div>
        <div class="tech-card">
          <div class="tech-card-icon" style="background: rgba(6,182,212,0.10); color: #22d3ee;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 7l-7 5 7 5V7z"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
          </div>
          <h3 data-i18n="tech.card2.title">Zoom calls & meetings</h3>
          <p data-i18n="tech.card2.desc">Speak up in standups, contribute to discussions, and handle Q&A with confidence.</p>
        </div>
        <div class="tech-card">
          <div class="tech-card-icon" style="background: rgba(52,211,153,0.10); color: #34d399;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
          </div>
          <h3 data-i18n="tech.card3.title">Job interviews</h3>
          <p data-i18n="tech.card3.desc">Technical interviews, behavioral questions, salary negotiations — practice the exact conversations you'll face.</p>
        </div>
        <div class="tech-card">
          <div class="tech-card-icon" style="background: rgba(251,191,36,0.10); color: #fbbf24;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
          </div>
          <h3 data-i18n="tech.card4.title">Explaining bugs & technical issues</h3>
          <p data-i18n="tech.card4.desc">Describe problems clearly, propose solutions, and communicate technical concepts to non-technical stakeholders.</p>
        </div>
        <div class="tech-card">
          <div class="tech-card-icon" style="background: rgba(168,85,247,0.10); color: #a855f7;">
