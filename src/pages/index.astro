---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="English Tutor in Mexico | Native English Coaching Online" description="Personalized online English lessons for professionals and students in Mexico. Native US English speaker focused on conversation and confidence.">
  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="hero-glow">
      <div class="hero-glow-indigo"></div>
      <div class="hero-glow-cyan"></div>
    </div>
    <div class="hero-grid">
      <div class="hero-left">
        <div class="hero-badge">
          <span class="hero-badge-dot"></span>
          <span data-i18n="hero.badge">Coaching de inglés para profesionales</span>
        </div>
        <h1 class="hero-heading">
          <span data-i18n="hero.heading1">English coaching</span>
          <span class="hero-heading-gradient" data-i18n="hero.heading2">for professionals in Mexico</span>
        </h1>
        <p class="hero-subtitle" data-i18n="hero.subtitle">
          Personalized online lessons with a native US English speaker.
          Improve conversation, interviews, meetings, and confidence.
        </p>
        <div class="hero-cta">
          <a href="/book" class="hero-btn-primary" data-i18n="hero.btn1">Book Free Consultation</a>
          <a href="/pricing" class="hero-btn-secondary" data-i18n="hero.btn2">View Pricing</a>
          <a href="https://wa.me/16193946221" target="_blank" rel="noopener" class="hero-btn-whatsapp">
            <svg class="whatsapp-inline-icon" viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            <span data-i18n="hero.btn3">Questions? Message me</span>
          </a>
        </div>
        <div class="hero-stats">
          <div>
            <div class="hero-stat-num" data-i18n="hero.stat1a">Google Meet</div>
            <div class="hero-stat-label" data-i18n="hero.stat1b">Online sessions</div>
          </div>
          <div>
            <div class="hero-stat-num" data-i18n="hero.stat2a">Native US</div>
            <div class="hero-stat-label" data-i18n="hero.stat2b">English speaker</div>
          </div>
          <div>
            <div class="hero-stat-num" data-i18n="hero.stat3a">MXN</div>
            <div class="hero-stat-label" data-i18n="hero.stat3b">Pay in pesos</div>
          </div>
        </div>
      </div>
      <div class="hero-right">
        <div class="hero-frame">
          <img src="https://avatars.githubusercontent.com/u/282408621?v=4" alt="Mauricio Tellez" class="hero-img" loading="eager" />
        </div>
      </div>
    </div>
  </section>

  <!-- ===== WHO THIS IS FOR ===== -->
  <section class="section section-divider">
    <div class="container">
      <div class="mini-section" style="margin-bottom: 3rem;">
        <div class="section-eyebrow" data-i18n="who.eyebrow">Who I Help</div>
        <h2 class="section-title" data-i18n="who.title">¿A quién ayudo?</h2>
        <p class="section-desc" data-i18n="who.desc">Profesionales y estudiantes que quieren hablar inglés con confianza.</p>
      </div>
      <div class="grid-3">
        <div class="who-card">
          <div class="who-icon" style="background: rgba(99,102,241,0.12); color: #818cf8;">&lt;/&gt;</div>
          <h3 data-i18n="who.card1">Software Developers</h3>
          <p data-i18n="who.card1.desc">Mejora tu inglés técnico para trabajar en equipos internacionales.</p>
        </div>
        <div class="who-card">
          <div class="who-icon" style="background: rgba(6,182,212,0.12); color: #22d3ee;">🏠</div>
          <h3 data-i18n="who.card2">Remote Workers</h3>
          <p data-i18n="who.card2.desc">Comunícate mejor con colegas y clientes de habla inglesa.</p>
        </div>
        <div class="who-card">
          <div class="who-icon" style="background: rgba(52,211,153,0.12); color: #34d399;">🎓</div>
          <h3 data-i18n="who.card3">University Students</h3>
          <p data-i18n="who.card3.desc">Prepárate para intercambios, lecturas académicas y exámenes.</p>
        </div>
        <div class="who-card">
          <div class="who-icon" style="background: rgba(251,191,36,0.12); color: #fbbf24;">💼</div>
          <h3 data-i18n="who.card4">Job Seekers</h3>
          <p data-i18n="who.card4.desc">Domina entrevistas en inglés y destaca en tu búsqueda laboral.</p>
        </div>
        <div class="who-card">
          <div class="who-icon" style="background: rgba(244,114,182,0.12); color: #f472b6;">📊</div>
          <h3 data-i18n="who.card5">Professionals</h3>
          <p data-i18n="who.card5.desc">Inglés para juntas, presentaciones y comunicación ejecutiva.</p>
        </div>
        <div class="who-card">
          <div class="who-icon" style="background: rgba(168,85,247,0.12); color: #a855f7;">💬</div>
          <h3 data-i18n="who.card6">Struggling Speakers</h3>
          <p data-i18n="who.card6.desc">Entiendes pero te cuesta hablar. Trabajemos eso.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== WHAT WE FOCUS ON ===== -->
  <section class="section section-divider bg-subtle">
    <div class="container">
      <div class="mini-section" style="margin-bottom: 3rem;">
        <div class="section-eyebrow" data-i18n="focus.eyebrow">What We Focus On</div>
        <h2 class="section-title" data-i18n="focus.title">¿En qué nos enfocamos?</h2>
        <p class="section-desc" data-i18n="focus.desc">En comunicación real, no en gramática de libro.</p>
      </div>
      <div class="focus-grid">
        <div class="focus-item">
          <span class="focus-icon">🗣️</span>
          <div>
            <strong data-i18n="focus.item1">Speaking naturally in conversations</strong>
            <p data-i18n="focus.item1.desc">Aprende a expresarte sin traducir mentalmente.</p>
          </div>
        </div>
        <div class="focus-item">
          <span class="focus-icon">💪</span>
          <div>
            <strong data-i18n="focus.item2">Building confidence</strong>
            <p data-i18n="focus.item2.desc">Pierde el miedo a hablar y cometer errores.</p>
          </div>
        </div>
        <div class="focus-item">
          <span class="focus-icon">👂</span>
          <div>
            <strong data-i18n="focus.item3">Understanding native speakers</strong>
            <p data-i18n="focus.item3.desc">Mejora tu comprensión del inglés natural y rápido.</p>
          </div>
        </div>
        <div class="focus-item">
          <span class="focus-icon">🎤</span>
          <div>
            <strong data-i18n="focus.item4">Interview preparation</strong>
            <p data-i18n="focus.item4.desc">Practica preguntas y respuestas para entrevistas reales.</p>
          </div>
        </div>
        <div class="focus-item">
          <span class="focus-icon">📧</span>
          <div>
            <strong data-i18n="focus.item5">Business communication</strong>
            <p data-i18n="focus.item5.desc">Correos, juntas, presentaciones y negociaciones.</p>
          </div>
        </div>
        <div class="focus-item">
          <span class="focus-icon">🎯</span>
          <div>
            <strong data-i18n="focus.item6">Pronunciation and fluency</strong>
            <p data-i18n="focus.item6.desc">Suena más natural y que te entiendan mejor.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== HOW LESSONS WORK ===== -->
  <section class="section section-divider">
    <div class="container">
      <div class="mini-section" style="margin-bottom: 3rem;">
        <div class="section-eyebrow" data-i18n="how.eyebrow">How Lessons Work</div>
        <h2 class="section-title" data-i18n="how.title">¿Cómo funcionan las sesiones?</h2>
      </div>
      <div class="steps-grid">
        <div class="step-card glass-step">
          <div class="step-num" style="color: #818cf8;">01</div>
          <h3 data-i18n="how.step1.title">Free Consultation</h3>
          <p data-i18n="how.step1.desc">We discuss your goals and current level.</p>
        </div>
        <div class="step-card glass-step">
          <div class="step-num" style="color: #22d3ee;">02</div>
          <h3 data-i18n="how.step2.title">Personalized Lessons</h3>
          <p data-i18n="how.step2.desc">Lessons are adapted to your needs and interests.</p>
        </div>
        <div class="step-card glass-step">
          <div class="step-num" style="color: #34d399;">03</div>
          <h3 data-i18n="how.step3.title">Consistent Speaking Practice</h3>
          <p data-i18n="how.step3.desc">Improve confidence through real conversation.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== NO PRESSURE / RELAXED LESSONS ===== -->
  <section class="section section-divider bg-subtle">
    <div class="container">
      <div class="surface relaxed-card">
        <div class="relaxed-content">
          <div class="section-eyebrow-light" data-i18n="relaxed.eyebrow">Sin presiones</div>
          <h2 class="section-title" data-i18n="relaxed.title">Relaxed, practical lessons</h2>
          <p class="relaxed-desc" data-i18n="relaxed.desc">Lessons are conversational and adapted to your pace. Mistakes are normal. The goal is real communication and confidence.</p>
          <a href="/book" class="btn-primary" data-i18n="relaxed.btn">Book Free Consultation</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section class="section section-divider" id="faq">
    <div class="container">
      <div class="surface">
        <div class="faq-inner">
          <div class="section-eyebrow-light" style="text-align: center;" data-i18n="faq.eyebrow">FAQ</div>
          <h2 class="section-title" style="text-align: center; margin-bottom: 2.5rem;" data-i18n="faq.title">Common questions</h2>
          <div class="faq-grid">
            <div class="faq-card">
              <h3 data-i18n="faq.q1">Do I need perfect English?</h3>
              <p data-i18n="faq.a1">No. Lessons are adapted to your level.</p>
            </div>
            <div class="faq-card">
              <h3 data-i18n="faq.q2">Are lessons online?</h3>
              <p data-i18n="faq.a2">Yes — via Google Meet, Zoom, or Discord.</p>
            </div>
            <div class="faq-card">
              <h3 data-i18n="faq.q3">Can you help with interviews?</h3>
              <p data-i18n="faq.a3">Yes. Interview prep is one of my specialties.</p>
            </div>
            <div class="faq-card">
              <h3 data-i18n="faq.q4">Do you teach beginners?</h3>
              <p data-i18n="faq.a4">Yes, but lessons focus on speaking and practical communication from day one.</p>
            </div>
            <div class="faq-card">
              <h3 data-i18n="faq.q5">Can I reschedule?</h3>
              <p data-i18n="faq.a5">Yes, with 24 hours advance notice.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="section-cta">
    <div class="cta-glow"></div>
    <div class="cta-inner">
      <h2 data-i18n="cta.title">Ready to start speaking more confidently?</h2>
      <p data-i18n="cta.desc">Book your free consultation and take the first step.</p>
      <a href="/book" class="cta-btn" data-i18n="cta.btn">Start Speaking More Confidently</a>
    </div>
  </section>
</BaseLayout>

<style is:global>
  /* ---- Hero ---- */
  .hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .hero-glow { position: absolute; inset: 0; pointer-events: none; }
  .hero-glow-indigo {
    position: absolute; left: -10%; top: -10%;
    width: 500px; height: 500px; border-radius: 50%;
    background: rgba(99,102,241,0.20); filter: blur(100px);
  }
  .hero-glow-cyan {
    position: absolute; right: -10%; bottom: -20%;
    width: 600px; height: 600px; border-radius: 50%;
    background: rgba(6,182,212,0.10); filter: blur(120px);
  }
  .hero-grid {
    position: relative;
    display: grid;
    gap: 5rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 6rem 1.5rem;
  }
  @media (min-width: 1024px) {
    .hero-grid {
      grid-template-columns: 1.1fr 0.9fr;
      align-items: center;
      padding: 8rem 2rem;
      gap: 5rem;
    }
  }
  .hero-left { max-width: 560px; }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.35rem 1rem; border-radius: 9999px;
    font-size: 0.875rem; color: #a5b4fc;
    background: rgba(99,102,241,0.10);
    border: 1px solid rgba(99,102,241,0.2);
  }
  .hero-badge-dot { width: 0.5rem; height: 0.5rem; border-radius: 50%; background: #34d399; }
  .hero-heading {
    margin-top: 2rem;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 800; letter-spacing: -0.04em;
    line-height: 0.95; color: #fff;
  }
  .hero-heading-gradient {
    display: block;
    background: linear-gradient(135deg, #818cf8, #22d3ee);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-subtitle {
    margin-top: 2rem; max-width: 560px;
    font-size: 1.125rem; line-height: 1.8; color: #94a3b8;
  }
  .hero-cta { margin-top: 2.5rem; display: flex; flex-wrap: wrap; gap: 1rem; }
  .hero-btn-primary, .hero-btn-secondary {
    display: inline-flex; align-items: center; justify-content: center;
    padding: 0.875rem 1.5rem; border-radius: 16px;
    font-size: 0.875rem; font-weight: 600;
    transition: all 0.2s; text-decoration: none !important;
  }
  .hero-btn-primary {
    background: #6366f1; color: #fff !important;
    box-shadow: 0 4px 14px rgba(99,102,241,0.3);
  }
  .hero-btn-primary:hover { background: #818cf8; }
  .hero-btn-secondary {
    background: rgba(255,255,255,0.05); color: #fff !important;
    border: 1px solid rgba(255,255,255,0.1);
  }
  .hero-btn-secondary:hover { background: rgba(255,255,255,0.1); }
  .whatsapp-inline-icon { width: 1.1rem; height: 1.1rem; flex-shrink: 0; }
  .hero-btn-whatsapp {
    display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem;
    padding: 0.875rem 1.5rem; border-radius: 50px;
    font-size: 0.875rem; font-weight: 600;
    transition: all 0.2s; text-decoration: none !important;
    background: #25D366; color: #fff !important;
    box-shadow: 0 4px 14px rgba(37,211,102,0.35);
  }
  .hero-btn-whatsapp:hover {
    background: #20bd5a; transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(37,211,102,0.4);
  }
  .hero-stats {
    margin-top: 3.5rem; padding-top: 2rem;
    border-top: 1px solid rgba(255,255,255,0.08);
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem;
  }
  .hero-stat-num { font-size: 1.5rem; font-weight: 700; color: #fff; }
  .hero-stat-label { margin-top: 0.25rem; font-size: 0.875rem; color: #64748b; }

  .hero-right { position: relative; width: 100%; max-width: 480px; margin: 0 auto; }
  .hero-frame {
    position: relative; overflow: hidden; border-radius: 36px;
    border: 1px solid rgba(255,255,255,0.1);
    background: rgba(15,23,42,0.8); padding: 1rem;
    box-shadow: 0 20px 60px rgba(99,102,241,0.08);
    backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
  }
  .hero-img { aspect-ratio: 4/5; width: 100%; border-radius: 28px; object-fit: cover; }

  @media (width <= 640px) {
    .hero-grid { padding: 4rem 1rem; gap: 3rem; }
    .hero-stats { grid-template-columns: repeat(3, 1fr); gap: 1rem; }
    .hero-stat-num { font-size: 1.15rem; }
  }

  /* ---- Section utilities ---- */
  .section-eyebrow-light {
    font-size: 0.8rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.15em;
    color: #64748b; margin-bottom: 1rem;
  }

  /* ---- Who cards grid ---- */
  .grid-3 { display: grid; gap: 1rem; }
  @media (min-width: 640px) { .grid-3 { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 900px) { .grid-3 { grid-template-columns: repeat(3, 1fr); } }
  .who-card {
    padding: 1.5rem; border-radius: 20px;
    background: rgba(15,23,42,0.65);
    backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255,255,255,0.08);
    transition: all 0.2s;
  }
  .who-card:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(0,0,0,0.2); }
  .who-icon {
    width: 2.5rem; height: 2.5rem; border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1rem; font-weight: 700; margin-bottom: 1rem;
  }
  .who-card h3 { font-size: 1rem; font-weight: 700; color: #fff; margin-bottom: 0.5rem; }
  .who-card p { font-size: 0.85rem; color: #94a3b8; line-height: 1.6; }

  /* ---- Focus grid ---- */
  .focus-grid { display: grid; gap: 0.75rem; max-width: 720px; margin: 0 auto; }
  .focus-item {
    display: flex; align-items: flex-start; gap: 1rem;
    padding: 1rem 1.25rem; border-radius: 16px;
    background: rgba(15,23,42,0.4);
    border: 1px solid rgba(255,255,255,0.06);
  }
  .focus-icon { font-size: 1.3rem; flex-shrink: 0; margin-top: 0.1rem; }
  .focus-item strong { font-size: 0.95rem; color: #fff; display: block; margin-bottom: 0.2rem; }
  .focus-item p { font-size: 0.85rem; color: #64748b; line-height: 1.5; }

  /* ---- Steps (reuse existing) ---- */
  .steps-grid { display: grid; gap: 1.5rem; }
  @media (min-width: 768px) { .steps-grid { grid-template-columns: repeat(3, 1fr); } }
  .glass-step {
    padding: 2rem; border-radius: 20px;
    background: rgba(15,23,42,0.65);
    backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255,255,255,0.08);
    transition: all 0.2s;
  }
  .glass-step:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(0,0,0,0.2); }
  .step-num { font-size: 2.5rem; font-weight: 800; line-height: 1; margin-bottom: 1.5rem; }
  .glass-step h3 { font-size: 1.15rem; font-weight: 700; color: #fff; margin-bottom: 0.75rem; }
  .glass-step p { font-size: 0.9rem; color: #94a3b8; line-height: 1.7; }

  /* ---- Relaxed section ---- */
  .relaxed-card { text-align: center; padding: 3rem; max-width: 640px; margin: 0 auto; }
  .relaxed-content { max-width: 520px; margin: 0 auto; }
  .relaxed-desc { font-size: 1.05rem; color: #94a3b8; line-height: 1.8; margin-top: 1.25rem; margin-bottom: 2rem; }

  /* ---- FAQ ---- */
  .faq-inner { max-width: 720px; margin: 0 auto; }
  .faq-grid { display: grid; gap: 1rem; }
  @media (min-width: 640px) { .faq-grid { grid-template-columns: 1fr 1fr; } }
  .faq-card { padding: 1.25rem; border-radius: 20px; background: rgba(255,255,255,0.03); }
  .faq-card h3 { font-size: 1rem; font-weight: 600; color: #fff; margin-bottom: 0.5rem; }
  .faq-card p { font-size: 0.9rem; color: #94a3b8; line-height: 1.6; }

  /* ---- CTA ---- */
  .section-cta {
    position: relative; overflow: hidden; padding: 5rem 0;
    background: linear-gradient(135deg, rgba(99,102,241,0.12), rgba(6,182,212,0.06));
    border-top: 1px solid rgba(255,255,255,0.06);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .cta-glow {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(99,102,241,0.15), transparent 50%);
    pointer-events: none;
  }
  .cta-inner {
    position: relative; max-width: 520px; margin: 0 auto;
    text-align: center; padding-inline: 1.5rem;
  }
  .cta-inner h2 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800; color: #fff; letter-spacing: -0.03em; margin-bottom: 0.75rem;
  }
  .cta-inner p { font-size: 1.05rem; color: #94a3b8; margin-bottom: 2rem; }
  .cta-btn {
    display: inline-flex; align-items: center;
    padding: 0.875rem 2.5rem; border-radius: 16px;
    background: #fff; color: #0f172a !important;
    font-weight: 600; font-size: 0.9rem;
    box-shadow: 0 4px 20px rgba(0,0,0,0.2);
    transition: all 0.2s; text-decoration: none !important;
  }
