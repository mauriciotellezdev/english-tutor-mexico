---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Tutor Login | English Immersion" description="Teacher login for the English Immersion platform.">
  <section class="auth-page">
    <div class="auth-container">
      <div class="auth-card">
        <div class="auth-header">
          <h1>Tutor OS</h1>
          <p>Sign in with your teacher account.</p>
        </div>

        <div id="login-status" class="auth-status" style="display: none;"></div>

        <form id="teacher-login-form" class="auth-form">
          <div class="form-group">
            <label for="teacher-email">Email address</label>
            <input
              type="email"
              id="teacher-email"
              name="email"
              placeholder="mauricio@email.com"
              required
              autocomplete="email"
            />
          </div>

          <button type="submit" id="teacher-login-btn" class="auth-btn-primary">
            <span class="btn-text">Send Magic Link</span>
            <span class="btn-loading" style="display: none;">Sending magic link...</span>
          </button>
        </form>

        <div class="auth-footer">
          <a href="/">← Back to site</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import { supabase } from '@/lib/supabase';

  const form = document.getElementById('teacher-login-form');
  const btn = document.getElementById('teacher-login-btn');
  const btnText = btn?.querySelector('.btn-text');
  const btnLoading = btn?.querySelector('.btn-loading');
  const status = document.getElementById('login-status');

  // Check if already logged in as teacher
  supabase.auth.getSession().then(async ({ data: { session } }) => {
    if (session) {
      const { data: profile } = await supabase
        .from('profiles')
        .select('role')
        .eq('id', session.user.id)
        .single();
      if (profile?.role === 'teacher') {
        window.location.href = '/teacher/dashboard';
      }
    }
  });

  // Worker URL for sending magic links (bypasses Supabase SMTP)
  const WORKER_URL = 'https://english-tutor-mexico-worker.mauriciotellezdev.workers.dev';

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const emailInput = document.getElementById('teacher-email') as HTMLInputElement;
    const email = emailInput?.value.trim();

    if (!email) {
      showStatus('Please enter your email address.', 'error');
      return;
    }

    if (btnText) btnText.style.display = 'none';
    if (btnLoading) btnLoading.style.display = 'block';
    if (btn) btn.disabled = true;

    const timeout = setTimeout(() => {
      showStatus('Request timed out. Please try again.', 'error');
      if (btnText) btnText.style.display = 'block';
      if (btnLoading) btnLoading.style.display = 'none';
      if (btn) btn.disabled = false;
    }, 15000);

    try {
      const resp = await fetch(`${WORKER_URL}/api/send-magic-link`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email,
          redirectTo: `${window.location.origin}/teacher/callback`,
          type: 'magiclink',
        }),
      });

      clearTimeout(timeout);

      if (!resp.ok) {
        const err = await resp.json();
        throw new Error(err.error || 'Failed to send magic link');
      }

      showStatus(
        `Magic link sent to ${email}! Check your inbox and click the link.`,
        'success'
      );
      form.reset();
    } catch (err: any) {
      clearTimeout(timeout);
      console.error('[Teacher Login] Error:', err);
      showStatus(err.message || 'Something went wrong. Please try again.', 'error');
    } finally {
      if (btnText) btnText.style.display = 'block';
      if (btnLoading) btnLoading.style.display = 'none';
      if (btn) btn.disabled = false;
    }
  });

  function showStatus(message: string, type: 'success' | 'error') {
    if (!status) return;
    status.textContent = message;
    status.className = `auth-status auth-status-${type}`;
    status.style.display = 'block';
  }
</script>

<style is:global>
  .auth-page {
    min-height: calc(100vh - 200px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem 1.5rem;
  }
  .auth-container { width: 100%; max-width: 440px; }
  .auth-card {
    padding: 2.5rem;
    border-radius: 24px;
    background: rgba(15,23,42,0.65);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255,255,255,0.08);
  }
  .auth-header h1 {
    font-size: 1.75rem;
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.03em;
    margin-bottom: 0.5rem;
  }
  .auth-header p {
    font-size: 0.95rem;
    color: #94a3b8;
    line-height: 1.6;
    margin-bottom: 2rem;
  }
  .auth-form { display: flex; flex-direction: column; gap: 1.25rem; }
  .form-group { display: flex; flex-direction: column; gap: 0.4rem; }
  .form-group label { font-size: 0.85rem; font-weight: 600; color: #cbd5e1; }
  .form-group input {
    padding: 0.75rem 1rem;
    border-radius: 12px;
    border: 1px solid rgba(255,255,255,0.1);
    background: rgba(255,255,255,0.05);
    color: #fff;
    font-size: 0.95rem;
    font-family: inherit;
    outline: none;
    transition: border-color 0.2s;
  }
  .form-group input:focus { border-color: #6366f1; }
  .form-group input::placeholder { color: #64748b; }
  .auth-btn-primary {
    padding: 0.875rem 1.5rem;
    border-radius: 14px;
    background: #6366f1;
    color: #fff;
    font-size: 0.95rem;
    font-weight: 600;
    border: none;
    cursor: pointer;
    transition: all 0.2s;
    font-family: inherit;
    margin-top: 0.5rem;
  }
  .auth-btn-primary:hover { background: #818cf8; }
  .auth-btn-primary:disabled { opacity: 0.6; cursor: not-allowed; }
  .auth-status {
    padding: 0.875rem 1rem;
    border-radius: 12px;
    font-size: 0.9rem;
    margin-bottom: 1.25rem;
    line-height: 1.5;
  }
  .auth-status-success {
    background: rgba(52,211,153,0.1);
    border: 1px solid rgba(52,211,153,0.2);
    color: #34d399;
  }
  .auth-status-error {
    background: rgba(248,113,113,0.1);
    border: 1px solid rgba(248,113,113,0.2);
    color: #f87171;
  }
  .auth-footer {
    margin-top: 1.5rem;
    text-align: center;
    font-size: 0.9rem;
  }
  .auth-footer a { color: #818cf8; font-weight: 500; }
  .auth-footer a:hover { color: #a5b4fc; }

  @media (width <= 640px) {
    .auth-card { padding: 1.75rem; }
  }
</style>
