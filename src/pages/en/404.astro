---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Página no encontrada">
  <section class="not-found">
    <div class="container">
      <h1>404</h1>
      <p>Página no encontrada.</p>
      <a href="/" class="btn-primary">Ir al inicio</a>
    </div>
  </section>
</BaseLayout>

<style is:global>
  .not-found { text-align: center; padding: 6rem 0; }
  .not-found h1 { font-size: 5rem; color: var(--c-indigo); margin-bottom: 0.5rem; }
  .not-found p { font-size: 1.25rem; color: var(--text-muted); margin-bottom: 2rem; }
</style>
