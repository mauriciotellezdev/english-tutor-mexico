---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Pago recibido">
  <section class="page-header">
    <div class="container">
      <div class="section-label">Confirmado</div>
      <h1>¡Pago recibido!</h1>
      <p style="max-width: 480px; margin: 1rem auto 0;">Gracias por tu compra. Te enviaré un correo dentro de las próximas 24 horas para agendar tu primera clase.</p>
      <div style="margin-top: 2.5rem;">
        <a href="/" class="btn-primary">Volver al inicio</a>
      </div>
    </div>
  </section>
</BaseLayout>
