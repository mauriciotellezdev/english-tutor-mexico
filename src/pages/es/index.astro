---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { t } from "@/i18n/utils.ts";

const locale = "es";
---

<BaseLayout title="English Immersion in Mexico | AI-Assisted Conversational Coaching" description="AI-assisted conversational English immersion with a native US software engineer. Stop translating in your head. Start thinking in English.">
  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="hero-glow">
      <div class="hero-glow-indigo"></div>
      <div class="hero-glow-cyan"></div>
    </div>
    <div class="hero-grid">
      <div class="hero-left">
        <div class="hero-badge">
          <span class="hero-badge-dot"></span>
          <span>{t("hero.badge", locale)}</span>
        </div>
        <h1 class="hero-heading">
          <span>{t("hero.heading1", locale)}</span>
          <span class="hero-heading-gradient">{t("hero.heading2", locale)}</span>
        </h1>
        <p class="hero-subtitle">{t("hero.subtitle", locale)}</p>
        <div class="hero-cta">
          <a href="/book" class="hero-btn-primary">{t("hero.btn1", locale)}</a>
          <a href="/pricing" class="hero-btn-secondary">{t("hero.btn2", locale)}</a>
          <a href="https://wa.me/5212251118581" target="_blank" rel="noopener" class="hero-btn-whatsapp">
            <svg class="whatsapp-inline-icon" viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            <span>{t("hero.btn3", locale)}</span>
          </a>
        </div>
        <a href={`/${locale}/student/login`} class="hero-login-link">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
          {t("hero.loginLink", locale)}
        </a>
        <div class="hero-stats">
          <div>
            <div class="hero-stat-num">{t("hero.stat1a", locale)}</div>
            <div class="hero-stat-label">{t("hero.stat1b", locale)}</div>
          </div>
          <div>
            <div class="hero-stat-num">{t("hero.stat2a", locale)}</div>
            <div class="hero-stat-label">{t("hero.stat2b", locale)}</div>
          </div>
          <div>
            <div class="hero-stat-num">{t("hero.stat3a", locale)}</div>
            <div class="hero-stat-label">{t("hero.stat3b", locale)}</div>
          </div>
        </div>
      </div>
      <div class="hero-right">
        <div class="hero-frame">
          <img src="https://avatars.githubusercontent.com/u/282408621?v=4" alt="Mauricio Tellez" class="hero-img" loading="eager" />
        </div>
      </div>
    </div>
  </section>

  <!-- ===== WHO THIS IS FOR ===== -->
  <section class="section">
    <div class="container">
      <div class="mini-section" style="margin-bottom: 3rem;">
        <div class="section-eyebrow">{t("who.eyebrow", locale)}</div>
        <h2 class="section-title">{t("who.title", locale)}</h2>
        <p class="section-desc">{t("who.desc", locale)}</p>
      </div>
      <div class="who-grid">
        <div class="who-card">
          <div class="who-card-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          </div>
          <h3>{t("who.card1", locale)}</h3>
          <p>{t("who.card1.desc", locale)}</p>
        </div>
        <div class="who-card">
          <div class="who-card-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
          </div>
          <h3>{t("who.card2", locale)}</h3>
          <p>{t("who.card2.desc", locale)}</p>
        </div>
        <div class="who-card">
          <div class="who-card-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>
          <h3>{t("who.card3", locale)}</h3>
          <p>{t("who.card3.desc", locale)}</p>
        </div>
        <div class="who-card">
          <div class="who-card-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </div>
          <h3>{t("who.card4", locale)}</h3>
          <p>{t("who.card4.desc", locale)}</p>
        </div>
        <div class="who-card">
          <div class="who-card-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          </div>
          <h3>{t("who.card5", locale)}</h3>
          <p>{t("who.card5.desc", locale)}</p>
        </div>
        <div class="who-card">
          <div class="who-card-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
          </div>
          <h3>{t("who.card6", locale)}</h3>
          <p>{t("who.card6.desc", locale)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== WHAT WE FOCUS ON ===== -->
  <section class="section bg-subtle">
    <div class="container">
      <div class="focus-header">
        <div class="section-eyebrow">{t("focus.eyebrow", locale)}</div>
        <h2 class="section-title">{t("focus.title", locale)}</h2>
        <p class="section-desc">{t("focus.desc", locale)}</p>
      </div>
      <div class="focus-grid">
        <div class="focus-item">
          <span class="focus-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          </span>
          <div>
            <strong>{t("focus.item1", locale)}</strong>
            <p>{t("focus.item1.desc", locale)}</p>
          </div>
        </div>
        <div class="focus-item">
          <span class="focus-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </span>
          <div>
            <strong>{t("focus.item2", locale)}</strong>
            <p>{t("focus.item2.desc", locale)}</p>
          </div>
        </div>
        <div class="focus-item">
          <span class="focus-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 16.1A5 5 0 0 1 5.9 20M2 12.05A9 9 0 0 1 9.95 20M2 8V6a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2h-6"/><circle cx="2" cy="20" r="2"/></svg>
          </span>
          <div>
            <strong>{t("focus.item3", locale)}</strong>
            <p>{t("focus.item3.desc", locale)}</p>
          </div>
        </div>
        <div class="focus-item">
          <span class="focus-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
          </span>
          <div>
            <strong>{t("focus.item4", locale)}</strong>
            <p>{t("focus.item4.desc", locale)}</p>
          </div>
        </div>
        <div class="focus-item">
          <span class="focus-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
          </span>
          <div>
            <strong>{t("focus.item5", locale)}</strong>
            <p>{t("focus.item5.desc", locale)}</p>
          </div>
        </div>
        <div class="focus-item">
          <span class="focus-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>
          </span>
          <div>
            <strong>{t("focus.item6", locale)}</strong>
            <p>{t("focus.item6.desc", locale)}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== HOW LESSONS WORK ===== -->
  <section class="section">
    <div class="container">
      <div class="mini-section" style="margin-bottom: 3.5rem;">
        <div class="section-eyebrow">{t("how.eyebrow", locale)}</div>
        <h2 class="section-title">{t("how.title", locale)}</h2>
        <p class="section-desc">{t("how.desc", locale)}</p>
      </div>
      <div class="steps-grid">
        <div class="step-card">
          <div class="step-num">
            <span class="step-num-inner" style="color: #818cf8;">01</span>
          </div>
          <h3>{t("how.step1.title", locale)}</h3>
          <p>{t("how.step1.desc", locale)}</p>
        </div>
        <div class="step-card">
          <div class="step-num">
            <span class="step-num-inner" style="color: #22d3ee;">02</span>
          </div>
          <h3>{t("how.step2.title", locale)}</h3>
          <p>{t("how.step2.desc", locale)}</p>
        </div>
        <div class="step-card">
          <div class="step-num">
            <span class="step-num-inner" style="color: #34d399;">03</span>
          </div>
          <h3>{t("how.step3.title", locale)}</h3>
          <p>{t("how.step3.desc", locale)}</p>
        </div>
        <div class="step-card">
          <div class="step-num">
            <span class="step-num-inner" style="color: #fbbf24;">04</span>
          </div>
          <h3>{t("how.step4.title", locale)}</h3>
          <p>{t("how.step4.desc", locale)}</p>
        </div>
        <div class="step-card">
          <div class="step-num">
            <span class="step-num-inner" style="color: #f472b6;">05</span>
          </div>
          <h3>{t("how.step5.title", locale)}</h3>
          <p>{t("how.step5.desc", locale)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== WHY THIS WORKS BETTER ===== -->
  <section class="section bg-subtle">
    <div class="container">
      <div class="mini-section" style="margin-bottom: 3.5rem;">
        <div class="section-eyebrow">{t("why.eyebrow", locale)}</div>
        <h2 class="section-title">{t("why.title", locale)}</h2>
        <p class="section-desc">{t("why.desc", locale)}</p>
      </div>
      <div class="why-grid">
        <div class="why-card">
          <div class="why-card-header">
            <div class="why-card-icon" style="background: rgba(99,102,241,0.12); color: #818cf8;">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
            </div>
            <h3>{t("why.point1.title", locale)}</h3>
          </div>
          <p>{t("why.point1.desc", locale)}</p>
        </div>
        <div class="why-card">
          <div class="why-card-header">
            <div class="why-card-icon" style="background: rgba(244,114,182,0.12); color: #f472b6;">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <h3>{t("why.point2.title", locale)}</h3>
          </div>
          <p>{t("why.point2.desc", locale)}</p>
        </div>
        <div class="why-card">
          <div class="why-card-header">
            <div class="why-card-icon" style="background: rgba(6,182,212,0.12); color: #22d3ee;">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
            </div>
            <h3>{t("why.point3.title", locale)}</h3>
          </div>
          <p>{t("why.point3.desc", locale)}</p>
        </div>
        <div class="why-card">
          <div class="why-card-header">
            <div class="why-card-icon" style="background: rgba(52,211,153,0.12); color: #34d399;">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 10 10H12V2z"/><path d="M20.66 9A10 10 0 0 0 14 2v6.66z" opacity="0.5"/></svg>
            </div>
            <h3>{t("why.point4.title", locale)}</h3>
          </div>
          <p>{t("why.point4.desc", locale)}</p>
        </div>
        <div class="why-card">
          <div class="why-card-header">
            <div class="why-card-icon" style="background: rgba(251,191,36,0.12); color: #fbbf24;">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
            </div>
            <h3>{t("why.point5.title", locale)}</h3>
          </div>
          <p>{t("why.point5.desc", locale)}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== ENGLISH FOR TECH & REMOTE WORK ===== -->
  <section class="section">
    <div class="container">
      <div class="tech-header">
        <div class="section-eyebrow">{t("tech.eyebrow", locale)}</div>
        <h2 class="section-title">{t("tech.title", locale)}</h2>
        <p class="section-desc">{t("tech.desc", locale)}</p>
      </div>
      <div class="tech-grid">
        <div class="tech-card">
          <div class="tech-card-icon" style="background: rgba(99,102,241,0.10); color: #818cf8;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          </div>
          <h3>{t("tech.card1.title", locale)}</h3>
          <p>{t("tech.card1.desc", locale)}</p>
        </div>
        <div class="tech-card">
          <div class="tech-card-icon" style="background: rgba(6,182,212,0.10); color: #22d3ee;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 7l-7 5 7 5V7z"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
          </div>
          <h3>{t("tech.card2.title", locale)}</h3>
          <p>{t("tech.card2.desc", locale)}</p>
        </div>
        <div class="tech-card">
          <div class="tech-card-icon" style="background: rgba(52,211,153,0.10); color: #34d399;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
          </div>
          <h3>{t("tech.card3.title", locale)}</h3>
          <p>{t("tech.card3.desc", locale)}</p>
        </div>
        <div class="tech-card">
          <div class="tech-card-icon" style="background: rgba(251,191,36,0.10); color: #fbbf24;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
          </div>
          <h3>{t("tech.card4.title", locale)}</h3>
          <p>{t("tech.card4.desc", locale)}</p>
        </div>
        <div class="tech-card">
          <div class="tech-card-icon" style="background: rgba(168,85,247,0.10); color: #a855f7;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>
          <h3>{t("tech.card5.title", locale)}</h3>
          <p>{t("tech.card5.desc", locale)}</p>
        </div>
        <div class="tech-card">
          <div class="tech-card-icon" style="background: rgba(244,114,182,0.10); color: #f472b6;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
          </div>
          <h3>{t("tech.card6.title", locale)}</h3>
          <p>{t("tech.card6.desc", locale)}</p>
        </div>
      </div>
      <div class="tech-cta">
        <a href="/book" class="btn-primary">{t("tech.cta.btn", locale)}</a>
      </div>
    </div>
  </section>

  <!-- ===== RELAXED / NO PRESSURE ===== -->
  <section class="section bg-subtle">
    <div class="container">
      <div class="relaxed-card">
        <div class="relaxed-content">
          <div class="section-eyebrow-light">{t("relaxed.eyebrow", locale)}</div>
          <h2 class="section-title">{t("relaxed.title", locale)}</h2>
          <p class="relaxed-desc">{t("relaxed.desc", locale)}</p>
          <a href="/book" class="btn-primary">{t("relaxed.btn", locale)}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section class="section" id="faq">
    <div class="container">
      <div class="faq-surface">
